{
  "name": "tavreg-hikari",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "node --import tsx src/main.ts",
    "web:start": "bun run src/server/main.ts",
    "web:build": "vite build --config vite.config.ts",
    "web:dev": "vite --config vite.config.ts",
    "typecheck": "bunx tsc --noEmit",
    "test": "bun test",
    "ledger:query": "bun run src/ledger-cli.ts query",
    "proxy:check-all": "bun run src/proxy-cli.ts check-all",
    "proxy:check": "bun run src/proxy-cli.ts check",
    "proxy:set": "bun run src/proxy-cli.ts set"
  },
  "dependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/vite": "^4.2.1",
    "@vitejs/plugin-react": "^6.0.1",
    "dotenv": "^17.3.1",
    "impit": "^0.9.2",
    "playwright-core": "^1.58.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.2.1",
    "vite": "^8.0.0",
    "yaml": "^2.8.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "tsx": "^4.20.6"
  }
}
