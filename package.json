{
  "name": "tavreg-hikari",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "node --import tsx src/main.ts",
    "web:start": "bun run src/server/main.ts",
    "web:build": "vite build --config vite.config.ts",
    "web:dev": "vite --config vite.config.ts",
    "storybook": "storybook dev --config-dir .storybook --host 127.0.0.1 --port 56006 --disable-telemetry",
    "storybook:ci": "storybook dev --ci --no-open --config-dir .storybook --host 127.0.0.1 --port 56006 --disable-telemetry",
    "build-storybook": "storybook build --config-dir .storybook --output-dir storybook-static --disable-telemetry",
    "typecheck": "bunx tsc --noEmit",
    "test": "bun test",
    "ledger:query": "bun run src/ledger-cli.ts query",
    "proxy:check-all": "bun run src/proxy-cli.ts check-all",
    "proxy:check": "bun run src/proxy-cli.ts check",
    "proxy:set": "bun run src/proxy-cli.ts set"
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/vite": "^4.2.1",
    "@vitejs/plugin-react": "^6.0.1",
    "better-sqlite3": "^12.8.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.3.1",
    "impit": "^0.9.2",
    "lucide-react": "^0.577.0",
    "playwright-core": "^1.58.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "vite": "^8.0.0",
    "yaml": "^2.8.0"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^10.2.19",
    "@storybook/addon-docs": "^10.2.19",
    "@storybook/react-vite": "^10.2.19",
    "@types/better-sqlite3": "^7.6.13",
    "@types/bun": "latest",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "storybook": "^10.2.19",
    "tsx": "^4.20.6"
  }
}
