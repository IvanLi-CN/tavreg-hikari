{
  "schema_version": 1,
  "implementation_profile": "final",
  "policy": {
    "baseline_policy": "explicit-waiver-required",
    "require_signed_commits": true,
    "branch_protection": {
      "protected_branches": [
        "main"
      ],
      "require_pull_request": true,
      "disallow_direct_pushes": true,
      "disallow_branch_deletions": true,
      "disallow_force_pushes": true,
      "allow_merge_commits": true,
      "require_merge_queue": false,
      "required_reviewers": [],
      "required_status_checks": {
        "strict": true,
        "integrations": {
          "Validate PR labels": 15368,
          "Typecheck & Quality Gates": 15368,
          "Bun Tests": 15368,
          "Web Build": 15368,
          "Storybook Build": 15368,
          "Fingerprint Browser Install (macOS)": 15368,
          "Fingerprint Browser Install (Linux)": 15368,
          "Docker Smoke": 15368,
          "Review Policy Gate": 15368
        }
      }
    },
    "review_policy": {
      "mode": "conditional-required",
      "required_approvals": 1,
      "exempt_repository_owner": true,
      "exempt_author_permissions": [
        "admin",
        "maintain"
      ],
      "allowed_reviewer_permissions": [
        "write",
        "maintain",
        "admin"
      ],
      "enforcement": {
        "mode": "required-check",
        "check_name": "Review Policy Gate"
      }
    }
  },
  "required_checks": [
    "Validate PR labels",
    "Typecheck & Quality Gates",
    "Bun Tests",
    "Web Build",
    "Storybook Build",
    "Fingerprint Browser Install (macOS)",
    "Fingerprint Browser Install (Linux)",
    "Docker Smoke",
    "Review Policy Gate"
  ],
  "informational_checks": [],
  "waivers": [],
  "expected_pr_workflows": [
    {
      "workflow": "Label Gate",
      "jobs": [
        "Validate PR labels"
      ]
    },
    {
      "workflow": "CI PR",
      "jobs": [
        "Typecheck & Quality Gates",
        "Bun Tests",
        "Web Build",
        "Storybook Build",
        "Fingerprint Browser Install (macOS)",
        "Fingerprint Browser Install (Linux)",
        "Docker Smoke"
      ]
    },
    {
      "workflow": "Review Policy",
      "jobs": [
        "Review Policy Gate"
      ]
    }
  ],
  "expected_main_workflows": [
